# 🎵 Cấu hình Suno Music Composer

# Danh sách các API Keys từ Google AI Studio (aistudio.google.com)
# Ngăn cách nhau bởi dấu phẩy "," để tự động xoay vòng vòng tròn (Round-robin)
# và tự động phục hồi (Fallback) khi gặp lỗi Rate Limit (429).
GEMINI_KEYS=AIzaSy...your_key_1,AIzaSy...your_key_2

# Cổng chạy ứng dụng bên trong Container Docker (Mặc định: 8080)
PORT=8080

# Model AI sử dụng. Mặc định là gemini-2.0-flash (nhanh, rẻ và cực thông minh)
# Bạn có thể đổi sang gemini-1.5-pro nếu muốn chiều sâu thần học phức tạp hơn.
GEMINI_MODEL=gemini-2.0-flash
