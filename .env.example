# 🎵 Cấu hình Suno Music Composer


GEMINI_KEYS=AIzaSy...your_key

# Cổng chạy ứng dụng bên trong Container Docker (Mặc định: 8080)
PORT=8080

# Model AI sử dụng. Mặc định là gemini-2.0-flash (nhanh, rẻ và cực thông minh)
# Bạn có thể đổi sang gemini-1.5-pro nếu muốn chiều sâu thần học phức tạp hơn.
GEMINI_MODEL=gemini-2.0-flash
